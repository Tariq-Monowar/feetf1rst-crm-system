  // **Order no**
  // **Invoice No**

  // **Supplier**
  supplier String?

  // **Date**
  date DateTime?

  // **Amount**
  amount Float?

  // **Status (Ordered | Delivered | Partially)**
  status inventory_status?

  // **Payment (Open | Paid)**
  payment_status inventory_payment_status?

  // **Payment Date**
  payment_date DateTime?

  // **WE linked**
  we_linked Boolean?

  partnerId String
  partner   User   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  deleveary_note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model documents_and_claims {
  id String @id @default(cuid())

  partnerId String
  partner   User   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  type         document_type?
  number       String? // (	KV-2024-0078)
  reference    String? // AUF-2024-0898
  customerName String?
  recipient    String?
  in_total     Float?
  paid         Float?
  open         Float?

  payment_type inventory_payment_status? @map("payment_type")

  date       DateTime?
  created_by String?

  file String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum document_type {
  cost_estimate // KV-2024-0078
  invoices //	RE-2024-1201
  delivery_notes //LS-2024-0898	
}
