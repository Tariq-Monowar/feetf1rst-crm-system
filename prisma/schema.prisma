/**
 * @massschuhe_order "This is the main part of our application"
 * এটা হচ্চে জুতার অর্ডার মডেল
 * Q. how to order a shooe a customer?
 * A. every spapic partner has her own customer database. every customer has spapic insole and foot analysis and shoe.
 */

//  ================= V1========================
model massschuhe_order {
  id String @id @default(cuid())

  orderNumber Int?

  arztliche_diagnose    String?
  usführliche_diagnose String?
  rezeptnummer          String?
  durchgeführt_von     String?
  note                  String?

  albprobe_geplant   Boolean? @default(false)
  kostenvoranschlag  Boolean? @default(false)
  //-------------------------------------------------
  //workload section
  delivery_date      String?
  telefon            String?
  filiale            Json? //location - accepts any JSON data
  kunde              String? //customer name
  email              String?
  button_text        String?
  // PREISAUSWAHL
  fußanalyse        Float?
  einlagenversorgung Float?

  bodenerstellungpdf String?
  geliefertpdf       String?

  customer_note String?
  location      String?
  //-------------------------------------------------
  status        massschuhe_order_status @default(Leistenerstellung)
  express       Boolean?                @default(false)

  bezahlt paymnentStatus?

  //-------------------------------------------------
  cashNites     String?
  //
  isByPartner_1 Boolean? @default(false)
  isByPartner_2 Boolean? @default(false)

  production_startedAt DateTime?

  //relation with users
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  employeeId String?
  employee   Employees? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  customerId String?
  customer   customers? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  massschuheOrderHistories  massschuhe_order_history[]
  massschuheOrderInsurances massschuhe_order_insurance[]
  // massschuheOrderAdmin1s   massschuhe_order_admin_1[]
  customShafts              custom_shafts[]
  // adminOrderTransitions     admin_order_transitions[]

  isPanding       Boolean?         @default(false)
  courierContacts CourierContact[]
  customModels    custom_models[]
  ordersFeedbacks ordersFeedback[]

  @@unique([userId, orderNumber]) // Unique per partner
  @@index([createdAt])
  @@index([updatedAt])
}

enum massschuhe_order_status {
  Leistenerstellung //started

  Bettungsherstellung
  Halbprobenerstellung
  Schafterstellung
  Bodenerstellung

  Geliefert
}

model massschuhe_order_insurance {
  id String @id @default(cuid())

  orderId String
  order   massschuhe_order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  price Float?

  description Json?

  vat_country String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([price])
  @@index([description])
  @@index([createdAt])
  @@index([updatedAt])
}

model massschuhe_order_history {
  id String @id @default(cuid())

  statusFrom massschuhe_order_status?
  statusTo   massschuhe_order_status

  note String?

  startedAt  DateTime? // when the step begins
  finishedAt DateTime? // when the step is finished

  orderdAt           DateTime?        @default(now())
  massschuhe_orderId String
  massschuhe_order   massschuhe_order @relation(fields: [massschuhe_orderId], references: [id], onDelete: Cascade)

  partnerId String?
  partner   User?   @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  employeeId String?
  employee   Employees? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  customerId String?
  customer   customers? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([massschuhe_orderId])
  @@index([partnerId])
  @@index([employeeId])
  @@index([customerId])
}

//  ===================== V2 ======================
model shoe_order {
  id String @id @default(cuid())

  orderNumber Int?
  priority    Priority? @default(Normal)
  quantity    Int?

  /**
   * --------------
   * LOCATIONS
   * { title: string, description?: string }
   * ----------------
   */
  branch_location  Json?
  pick_up_location Json?

  /**
   * --------------
   * PAYMENT insurance or private
   * ----------------
   */
  payment_status   paymnentStatus?
  payment_type     paymnentType?
  insurance_status insurance_status? @default(pending)
  insurance_payed  Boolean?          @default(false)
  private_payed    Boolean?          @default(false)

  insurance_price Float?

  private_price Float?
  addon_price   Float?
  discount      Float?

  /**
   * 3rd fields
   * if it's private i get form input field
   * if it's insurance i get from dropdown
   */
  total_price Float?

  /**
   * government vat it's only for private order
   * if it's insurance i dont need this field
   */
  vat_rate Float?

  order_note  String?
  status_note String?

  //Ärztliche Diagnose (1st fields)
  medical_diagnosis  String?
  // Ausführliche Diagnose (2nd fields)
  detailed_diagnosis String?

  deposit_provision   Float?
  foot_analysis_price Json?

  store_location Json? // { title: string, description?: string }

  employeeId String?
  employee   Employees? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  kva       Boolean? @default(true)
  halbprobe Boolean? @default(true)
  kvaNumber Int? //it's start form 1
  kvaPdf    String?

  /**
   * ----------------------
   * PRODUCTION WORKFLOW
   * ----------------------
   */

  /**
   * if it's true{
   * i skip the
   * - Step 4 (Halbprobenerstellung)
   * - Step 5 (Halbprobe durchführen)
   * }
   */
  half_sample_required Boolean?

  /**
   * if it's false{
   * i skip the
   * - Step 2 (Leistenerstellung)
   * }
   */
  has_trim_strips Boolean?

  /**
   * if it's true{
   * i skip the
   * - Step 3 (Bettungserstellung)
   * }
   */
  bedding_required Boolean?

  supply_note String?

  insurances shoe_order_insurance[]

  // -- RELATIONS
  customerId String?
  customer   customers? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  partnerId String?
  partner   User?   @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  //prescription id
  prescriptionId String?
  prescription   prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  //relation 

  //relation with employee

  status String? @default("Auftragserstellung")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shoeOrderStep   shoe_order_step[]
  ordersFeedbacks ordersFeedback[]
  orderNotes      order_notes[]

  @@unique([partnerId, orderNumber]) // Unique per partner, starts from 1000
  @@index([partnerId, orderNumber])
  @@index([partnerId, status]) // Statistic cards: single-scan counts by status
}

enum insurance_status {
  pending
  approved
  rejected
}

enum paymnentType {
  insurance
  private
  broth
}

enum shoe_order_status {
  Auftragserstellung //step 1
  Leistenerstellung //step 2
  Bettungserstellung //step 3
  Halbprobenerstellung //step 4
  Halbprobe_durchführen //step 5
  Schaft_fertigen //step 6
  Bodenerstellen //step 7
  Qualitätskontrolle //step 8
  Abholbereit //step 9
  Ausgeführt //step 10
}

/**
 * 1. Auftragserstellung,
 * 2. Leistenerstellung,
 * 3. Bettungserstellung,
 * 4. Halbprobenerstellung,
 * 5. Halbprobe durchführen,
 * 6. Schaft fertigen,
 * 7. Bodenerstellen,
 * 8. Qualitätskontrolle,
 * 9. Abholbereit,
 * 10. Ausgeführt
 */

model shoe_order_step {
  id String @id @default(cuid())

  orderId String?
  order   shoe_order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  status String?

  isCompleted Boolean?  @default(false)
  complatedAt DateTime?
  /**
   * When this step actually started (can be before scheduled); used for time-spent calculation.
   */
  startedAt   DateTime?

  // step 1
  files files[]
  notes String?

  // step 2
  // files files[]
  // notes String?
  leistentyp     String?
  material       String?
  leistengröße String?

  // step 3
  // files files[]
  // notes String?
  //material string?
  step3_json           Json?
  // thickness            String?
  zusätzliche_notizen String?
  // dicke_ferse          String?
  // dicke_ballen         String?
  // dicke_spitze         String?

  // step 4
  fitting_date     DateTime? // it's was step 5
  preparation_date DateTime?
  // notes String

  /**
   * step 5
   */
  // files files[]
  // notes String
  checkliste_halbprobe Json? //other info

  adjustments      String?
  customer_reviews String?

  // step 6
  // files files[]
  // notes String

  // step 7
  // files files[]
  // notes String

  // step 8
  // files files[]
  // notes String

  // step 9
  // files files[]
  // notes String

  // step 10
  // files files[]
  // notes String

  auto_print Boolean? @default(false)

  //employee
  employeeId String?
  employee   Employees? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  partnerId String?
  partner   User?   @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  //step 5
  //three buttons
  feedback_status   step5_feedback_status?
  feedback_notes    String?
  Kleine_Nacharbeit Json?

  //schafttyp
  schafttyp_intem_note       String?
  schafttyp_extem_note       String?
  massschafterstellung_json  Json?
  massschafterstellung_image String?

  //bodenkonstruktion   
  bodenkonstruktion_intem_note String?
  bodenkonstruktion_extem_note String?
  bodenkonstruktion_json       Json?
  bodenkonstruktion_image      String?
}

// /// Step-5-specific data. Depends on status (Halbprobe_durchführen): one per order when that step is used, keyed by orderId.

enum step5_feedback_status {
  Freigeben
  Kleine_Nacharbeit
  große_Nacharbeiten
}

model files {
  id String @id @default(uuid())

  fileName String?
  fileUrl  String?
  fileType String?
  fileSize Float?

  createdAt DateTime @default(now())

  shoeOrderStep   shoe_order_step? @relation(fields: [shoeOrderStepId], references: [id])
  shoeOrderStepId String?
}

model shoe_order_insurance {
  id String @id @default(uuid())

  orderId String?
  order   shoe_order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  price       Float?
  description Json?
  vat_country String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

