/// Nested route tree per partner. Use parentId for nesting (e.g. Einstellungen -> Grundeinstellungen).
/// featureKey links to FeatureAccess field name for access control.
model Route {
  id         String  @id @default(uuid())
  title      String
  path       String
  action     Boolean @default(true)
  sortOrder  Int     @default(0)
  featureKey String?
  parentId   String?
  parent     Route?  @relation("RouteChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children   Route[] @relation("RouteChildren")

  partnerId String
  partner   User   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
  @@index([parentId])
  @@index([sortOrder])
  @@map("routes")
}

