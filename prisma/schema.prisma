// ===================== POS Receipt (Fiskaly SIGN IT — Italy) ======================
model pos_receipt {
  id String @id @default(uuid())

  orderId   String
  orderType String // "insole" | "shoes"

  paymentMethod String // "CASH"

  amount    Float
  vatRate   Float
  vatAmount Float
  subtotal  Float

  // Fiskaly SIGN IT fields (per integration PDF)
  fiskalyRecordId    String? // record_id from fiskaly response (TRANSACTION)
  fiskalyIntentionId String? // intention_id from fiskaly (needed for cancellation reference)
  fiskalySignature   String? // fiscal signature from fiskaly
  fiscalizedAt       DateTime? // when the receipt was fiscalized
  fiskalyMetadata    Json? // full fiskaly response (receipt metadata, PDF endpoint, etc.)

  // Stornierung (cancellation) — fiskaly SIGN IT INTENTION → TRANSACTION::CANCELLATION
  storniert            Boolean   @default(false)
  storniertAt          DateTime?
  storniertRecordId    String? // fiskaly record ID of the cancellation transaction
  storniertIntentionId String? // fiskaly intention ID used for the cancellation

  // Legacy TSE fields (German KassenSichV — kept for historical receipts)
  fiskalyTxId               String?
  fiskalyTxNumber           Int?
  fiskalyTssSerialNumber    String?
  fiskalyClientSerialNumber String?
  fiskalyTimeStart          DateTime?
  fiskalyTimeEnd            DateTime?
  fiskalySignatureValue     String?
  fiskalySignatureAlgorithm String?
  fiskalySignatureCounter   Int?
  fiskalySignaturePublicKey String?
  fiskalyQrCodeData         String?

  // Snapshot of receipt data (company, product, financial)
  receiptData Json?

  partnerId  String?
  partner    User?      @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  employeeId String?
  employee   Employees? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, orderType])
  @@index([partnerId])
  @@index([orderId])
}

